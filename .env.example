# Copy to .env for local dev — set the same keys in Vercel → Project → Settings → Environment Variables
# Never commit .env

# ——— Server only (Vercel + local vite proxy) ———
REELLY_API_KEY=

# ——— Public (VITE_ prefix) ———
VITE_APP_NAME=Kardosh Realty
VITE_CONTACT_EMAIL=info@kardoshrealty.ae
VITE_CONTACT_PHONE=+97141234567
VITE_SOCIAL_LINKEDIN=https://www.linkedin.com/in/allan-kardosh
VITE_SOCIAL_INSTAGRAM=https://www.instagram.com/kardoshrealtydubai

# Hero — local MP4 (recommended: faster, no YouTube play/pause chrome)
# 1. Put file at public/videos/dubai-hero.mp4 (keep under ~5 MB, 1080p H.264)
# 2. Enable local video and disable YouTube:
VITE_HERO_USE_LOCAL_VIDEO=true
VITE_HERO_VIDEO_URL=/videos/dubai-hero.mp4
# VITE_HERO_VIDEO_POSTER=/assets/images/bg/001.webp
# VITE_HERO_VIDEO_POSTER_FAST=/assets/images/bg/04.jpg
# Or YouTube instead (comment out USE_LOCAL_VIDEO and set):
# VITE_HERO_YOUTUBE_URL=https://youtu.be/YOUR_VIDEO_ID

# Supabase — contact form leads
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional analytics
# VITE_GTM_ID=
# VITE_GA_MEASUREMENT_ID=
# VITE_META_PIXEL_ID=
# VITE_WHATSAPP_PHONE=97141234567
